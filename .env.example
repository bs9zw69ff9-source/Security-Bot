# ── Discord app credentials (required) ─────────────────────────
DISCORD_TOKEN=
CLIENT_ID=
# Optional: your primary server's ID. Used for one-time .env → home-guild
# settings migration on boot, and to auto-seed + auto-post the default
# ticket panel/types for that one server (see README's Ticket system section).
GUILD_ID=

# ── Owner override(s) - always trusted, immune to every guard ────
# Comma-separated for multiple owners; BOT_OWNER_ID (singular) also still
# works and is merged in. Falls back to the ID baked into index.js if unset.
BOT_OWNER_IDS=
BOT_OWNER_ID=

# Optional: override the SQLite file path (defaults to guardian.db next to
# index.js). Mainly useful for pointing at a persistent volume, or for the
# test suite to isolate its own DB file.
GUARDIAN_DB_FILE=

# ── Home-guild defaults (seeded once into GUILD_ID's settings; use /setup afterwards) ──
LOG_CHANNEL_ID=
ALERT_CHANNEL_ID=
MESSAGE_LOG_CHANNEL_ID=
MOD_ROLE_ID=
MUTE_ROLE_ID=
NUKE_WHITELIST_ROLE_IDS=
NUKE_WHITELIST_USER_IDS=

# ── Anti-spam ────────────────────────────────────────────────────
SPAM_THRESHOLD=5
SPAM_WINDOW_MS=3000
SPAM_MUTE_MIN=10
SPAM_MENTION_LIMIT=6
SPAM_BLOCK_INVITES=true
SPAM_DUPLICATE_LIMIT=4
SPAM_EXEMPT_STAFF=true

# ── Anti-raid ─────────────────────────────────────────────────────
RAID_JOIN_THRESHOLD=10
RAID_WINDOW_MS=10000
RAID_LOCKDOWN_MIN=5
RAID_KICK_NEW_ON_LOCK=true
RAID_MIN_ACCOUNT_AGE_MIN=1440

# ── Anti-nuke (fast window) ───────────────────────────────────────
NUKE_WINDOW_MS=10000
NUKE_CHANNEL_THRESHOLD=3
NUKE_CHANNEL_CREATE_THRESH=4
NUKE_ROLE_THRESHOLD=3
NUKE_ROLE_CREATE_THRESH=4
NUKE_BAN_THRESHOLD=5
NUKE_KICK_THRESHOLD=5
NUKE_WEBHOOK_THRESHOLD=3
NUKE_BOT_ADD_ACTION=kick
NUKE_EMOJI_THRESHOLD=5

# ── Nuke recovery + hardening ─────────────────────────────────────
SNAPSHOT_INTERVAL_MS=1800000
SNAPSHOT_MAX=5
NUKE_STORM_THRESHOLD=3
NUKE_STORM_WINDOW_MS=60000
SCAM_BLOCK=true
OWNER_DM=true

# ── Mod rate limits (24h rolling window) ──────────────────────────
MOD_BAN_LIMIT=3
MOD_KICK_LIMIT=10
MOD_MUTE_LIMIT=20
MOD_PURGE_LIMIT=5
MOD_LOCKDOWN_LIMIT=5
MOD_WARN_LIMIT=30
MOD_WINDOW_MS=86400000

# ── Warn escalation (0 = disabled) ────────────────────────────────
WARN_MUTE_AT=3
WARN_KICK_AT=5
WARN_BAN_AT=7
WARN_MUTE_MIN=60

# ── Anti-ping ──────────────────────────────────────────────────────
ANTIPING_ENABLED=true
ANTIPING_ACTION=timeout
ANTIPING_TIMEOUT_MIN=5
ANTIPING_DELETE=false
ANTIPING_IGNORE_REPLIES=true
ANTIPING_NOTIFY=true
ANTIPING_RESPONSE={user}, please don't ping {targets}. You have been {action}.
ANTIPING_PROTECTED_USER_IDS=
ANTIPING_PROTECTED_ROLE_IDS=
